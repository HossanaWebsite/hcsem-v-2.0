    "aboutPageTitle": {
        "en": "About HCSEM",
        "am": "ስለ HCSEM"
    },
    "aboutPageSubtitle": {
        "en": "Building unity, honoring culture, and standing together in Minnesota.",
        "am": "ኢትዮጵያውያንን ማገናኘት፣ ባህልን መጠበቅ፣ በሜኒሶታ ጠንካራ ማህበረሰብ መገንባት"
    },
    "aboutPageImage": "/hero-home.png",
    "aboutMission": {
        "en": "Our mission is to support and uplift our members and the wider Ethiopian community by providing social, emotional, and humanitarian assistance, fostering cultural unity, and standing together during times of need, in accordance with the association’s by-laws.",
        "am": "የባለቤትነት እና የአንድነት ስሜትን ለማሳደግ..."
    },
    "aboutMissionImage": "/about-mission.png",
    "aboutVision": {
        "en": "Our vision is to build a strong, united, and compassionate community where members support one another, preserve their cultural values, empower future generations, and extend humanitarian help to Ethiopians affected by hardship both locally and beyond.",
        "am": "ቀዳሚ የኢትዮጵያ ማህበረሰብ ድርጅት ለመሆን..."
    },
